{
  "name": "catalystcare-chrome-extension",
  "displayName": "Catalystcare chrome extension",
  "version": "0.0.1",
  "description": "Vent out box and mental wellness tool",
  "author": "Sanket Agrawal <mailsanketagrawal@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/storage": "^1.15.0",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "^20.19.40",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "key": "$PLASMO_PUBLIC_CRX_KEY",
    "permissions": [
      "storage",
      "identity"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "oauth2": {
      "client_id": "$PLASMO_PUBLIC_GOOGLE_CLIENT_ID",
      "scopes": [
        "https://www.googleapis.com/auth/userinfo.email",
        "https://www.googleapis.com/auth/userinfo.profile"
      ]
    },
    "web_accessible_resources": [
      {
        "resources": ["tabs/auth.html"],
        "matches": ["<all_urls>"]
      }
    ]
  }
}
{
  "extends": "plasmo/templates/tsconfig.base",

  "compilerOptions": {
    "baseUrl": ".",

    "jsx": "react-jsx",

    "types": ["node", "chrome"],
    

    "paths": {
      "~*": ["./src/*"]
    }
  },

  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],

  "exclude": ["node_modules"]
}